{
  "name": "gapi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "gapi-front",
  "volta": {
    "node": "24.13.0",
    "pnpm": "10.29.2"
  },
  "keywords": [
    "react",
    "typescript",
    "vite",
    "shadcn"
  ],
  "author": "zhangzhouou@gmail.com",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "dev": "vite",
    "build:test": "tsc && vite build --mode test",
    "build": "tsc && vite build --mode prod",
    "test": "vitest",
    "test:staged": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:lint-staged": "lint-staged",
    "preview": "vite preview",
    "knip": "knip"
  },
  "lint-staged": {
    "*.{jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "{!(package)*.json,*.code-snippets,.!(browserslist)*rc}": [
      "prettier --write--parser json"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.{scss,less,styl,html}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "dependencies": {
